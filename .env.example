# AI CRM environment template
#
# Copy the values you need into:
# - apps/web/.env.local for local Next.js runtime
# - packages/db/.env for Prisma CLI commands
# - your production host's environment variable settings
#
# Never commit real secrets.

# Required in development and production.
DATABASE_URL="postgresql://ai_crm:ai_crm_local_password@127.0.0.1:55432/ai_crm?schema=public"

# App URL. Use the non-standard local port we use for this project to avoid clashes.
NEXT_PUBLIC_APP_URL="http://127.0.0.1:37173"

# Auth/session placeholders for the next auth integration step.
# Generate a strong value before enabling real auth.
AUTH_SECRET=""
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://127.0.0.1:37173"
CRM_ALLOWED_ADMIN_EMAILS="ekaterina.reyzbikh@gmail.com,olegp306@gmail.com"

# LLM provider for the live assistant runtime.
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-5.4-mini"
ANTHROPIC_API_KEY=""

# Email delivery placeholders.
RESEND_API_KEY=""
SMTP_HOST=""
SMTP_PORT=""
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM=""

# File/document storage placeholders.
STORAGE_PROVIDER="local"
LOCAL_STORAGE_DIR="./.local-storage"
S3_ENDPOINT=""
S3_BUCKET=""
S3_REGION="auto"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
SOFFICE_PATH=""

# Telegram L01 intake worker.
TELEGRAM_BOT_TOKEN=""
TELEGRAM_ALLOWED_CHAT_IDS=""
TELEGRAM_WORKSPACE_ID="workspace-demo"
TELEGRAM_POLL_INTERVAL_MS="5000"
TELEGRAM_TEST_MESSAGE=""
TELEGRAM_TEST_CHAT_ID=""
TELEGRAM_TEST_MESSAGE_ID=""
TELEGRAM_TEST_RECEIVED_AT=""

# Optional external integrations.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
SLACK_CLIENT_ID=""
SLACK_CLIENT_SECRET=""
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
