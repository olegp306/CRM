                              "alternate_identity_prompt":  "How should we address you here?",
                              "avoid_unnecessary_legal_name_prompt":  true,
                              "attribution_fields":  [
                                                         "link",
                                                         "campaign",
                                                         "referrer",
                                                         "channel",
                                                         "bot",
                                                         "product",
                                                         "landing_page",
                                                         "timestamp",
                                                         "first_touch"
                                                     ],
                              "activity_fields":  [
                                                      "bookings",
                                                      "payments",
                                                      "cancellations",
                                                      "feature_usage",
                                                      "failed_attempts",
                                                      "support_events",
                                                      "assistant_summaries",
                                                      "feature_requests"
                                                  ],
                              "commercial_fields":  [
                                                        "booking_count",
                                                        "payment_amounts",
                                                        "plan",
                                                        "lifetime_value",
                                                        "conversion_stage",
                                                        "purchase_intent",
                                                        "upsell_fit"
                                                    ],
                              "experience_fields":  [
                                                        "support_issues",
                                                        "objections",
                                                        "confusion",
                                                        "satisfaction_signals",
                                                        "churn_risks",
                                                        "quality_signals"
                                                    ]
                          },
    "ai_usage_abuse_protection":  {
                                      "enabled":  true,
                                      "prevent_general_ai_proxy_use":  true,
                                      "product_scope_required":  true,
                                      "detect_off_topic_general_requests":  true,
                                      "detect_generic_search_or_homework_use":  true,
