                                      "detect_high_volume_low_product_intent":  true,
                                      "detect_automation_or_bulk_queries":  true,
                                      "detect_resale_or_proxy_patterns":  true,
                                      "abuse_score_required":  true,
                                      "progressive_enforcement":  [
                                                                      "redirect_to_product_scope",
                                                                      "rate_limit",
                                                                      "quota_limit",
                                                                      "downgrade_to_cheaper_model",
                                                                      "mark_user_risk",
                                                                      "notify_admin",
                                                                      "temporary_suspend",
                                                                      "ban_for_repeated_or_severe_abuse"
                                                                  ],
                                      "admin_alert_required":  true,
                                      "cheaper_model_downgrade_allowed":  true,
                                      "temporary_suspension_allowed":  true,
                                      "ban_allowed_for_repeated_or_severe_abuse":  true,
                                      "expose_scores_or_thresholds_to_user":  false,
                                      "user_facing_response":  "This assistant can help with supported product tasks, but cannot help with unrelated or abusive use."
                                  },
    "local_development":  {
                              "assigned_ports":  {
                                                     "web":  4300,
                                                     "api":  4301,
                                                     "aux":  4302
                                                 },
