                              "preserve_first_touch":  true,
                              "preserve_campaign_metadata":  true,
                              "commercial_activity_tracking_required":  true,
                              "risk_and_value_signals_required":  true,
                              "expose_internal_scoring_to_user":  false,
                              "soft_identity_prompt_required":  true,
