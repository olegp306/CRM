{
    "schema_version":  "0.1",
    "project_id":  "crm",
    "name":  "CRM",
    "status":  "active",
    "category":  "crm_product",
    "owner":  "olegp306",
    "workspace":  "C:\\repos\\CRM",
    "repository":  {
                       "provider":  "github",
                       "name":  "olegp306/CRM",
                       "local_path":  "C:\\repos\\CRM"
                   },
    "founder_os":  {
                       "role":  "managed_product",
                       "managed_by_founder_os":  true,
                       "register_in_founder_os":  true
                   },
    "assistant":  {
                      "enabled":  true,
                      "token_tracking_required":  true,
                      "feedback_capture_required":  true,
                      "telegram_feature_pipeline_required":  true,
                      "tone_configurable":  true,
                      "personalization_allowed":  "light_consent_safe"
                  },
    "user_data":  {
                      "profile_policy":  "structured_facts_tags_summaries_only",
                      "raw_message_storage":  "disabled_by_default",
                      "consent_required_for_marketing":  true
                  },
    "events":  {
                   "emit_project_events":  true,
                   "emit_user_profile_events":  true,
                   "emit_token_usage_events":  true,
                   "emit_feedback_events":  true,
                   "emit_feature_signal_events":  true,
                   "emit_quality_signal_events":  true,
                   "emit_attribution_events":  true,
                   "emit_commercial_activity_events":  true,
                   "emit_risk_value_signal_events":  true,
                   "emit_abuse_signal_events":  true,
                   "emit_cost_control_events":  true
               },
    "deployment":  {
                       "model":  "founder_owned_product",
                       "targets":  [

                                   ]
                   },
    "notes":  "Founder-owned CRM product. Keep user intelligence and marketing hooks compatible with Founder OS.",
    "feature_intake":  {
                           "destination":  "founder_os_feature_inbox",
                           "source_channels":  [
                                                   "telegram_assistant",
                                                   "in_app_assistant",
                                                   "support_helper"
                                               ],
                           "raw_conversations":  "disabled_by_default",
                           "review_process":  "founder_brainstorm_before_roadmap"
                       },
    "quality":  {
                    "primary_value":  "user_value_and_quality_control",
                    "user_centricity_required":  true,
                    "contextual_offers_required":  true,
                    "generic_spam_allowed":  false,
                    "route_quality_signals_to_founder_os":  true
                },
    "feature_request_lifecycle":  {
                                      "thank_user_on_capture":  true,
                                      "appreciation_message_required":  true,
                                      "positive_emotive_marker_allowed":  true,
                                      "route_to_feature_inbox":  true,
                                      "preserve_request_to_release_link":  true,
                                      "notify_user_when_shipped":  true,
                                      "mention_in_release_notes":  true,
                                      "expose_internal_routing_to_user":  false
                                  },
    "self_improvement":  {
                             "enabled":  true,
                             "founder_sets_direction":  true,
                             "user_experience_growth_vector":  true,
                             "assistant_signal_extraction_required":  true,
                             "feedback_is_product_evolution_engine":  true,
                             "loop":  [
                                          "user_interaction",
                                          "assistant_signal_extraction",
                                          "founder_os_grouping",
                                          "founder_review_and_brainstorm",
                                          "approved_product_work",
                                          "release_linked_to_original_signals"
